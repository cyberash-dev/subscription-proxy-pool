{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"skipLibCheck": true,
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"lib": ["ES2022"],
		"types": ["node"]
	},
	"include": ["src/**/*.ts", "tests/**/*.ts"]
}
