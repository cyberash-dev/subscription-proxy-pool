{
	"name": "subscription-proxy-pool",
	"version": "0.0.1",
	"license": "MIT",
	"author": "cyberash",
	"description": "AI-subscription OAuth pool + Anthropic-compatible proxy for Claude Code — least-loaded selection, per-user/donor pools, two-level auth (OIDC identity + subscription OAuth)",
	"type": "module",
	"scripts": {
		"serve": "tsx src/cli/Main.ts serve",
		"migrate": "tsx src/cli/Main.ts migrate",
		"cli": "tsx src/cli/Main.ts",
		"test": "tsx tests/run-all.ts",
		"test:coverage": "c8 --config .c8rc.json tsx tests/run-all.ts",
		"coverage:ratchet": "node scripts/coverage-ratchet.mjs",
		"coverage:gate": "npm run test:coverage && npm run coverage:ratchet",
		"tsc": "tsc --noEmit",
		"lint:spec": "sdd lint",
		"sdd:lint": "sdd lint",
		"sdd:token": "sdd token",
		"sdd:check": "sdd check",
		"sdd:ready": "sdd ready",
		"lint": "eslint src tests",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"prepare": "git config core.hooksPath .githooks || true"
	},
	"dependencies": {
		"better-sqlite3": "11.10.0",
		"pg": "8.22.0",
		"undici": "6.27.0"
	},
	"devDependencies": {
		"@cyberash-dev/dev-tooling": "9.0.0",
		"@types/better-sqlite3": "7.6.13",
		"@types/node": "22.19.21",
		"@types/pg": "8.20.0",
		"agent-sdd": "1.3.0",
		"c8": "11.0.0",
		"eslint": "9.39.4",
		"prettier": "3.8.4",
		"tsx": "4.22.4",
		"typescript": "5.9.3"
	},
	"engines": {
		"node": ">=20"
	},
	"prettier": "@cyberash-dev/dev-tooling/prettier.base.json"
}
